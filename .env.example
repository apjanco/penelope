# API keys — referenced by ${VAR_NAME} in models.yaml
# Export these in your shell or put them here.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Legacy single-model config (used if no models.yaml exists)
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o
LLM_API_KEY=sk-...

# Optional: chunking defaults (can also be set in models.yaml)
CHUNK_SIZE=20000
CHUNK_OVERLAP=1000
